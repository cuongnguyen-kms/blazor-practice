@page "/"
@using BlazorBaseTemplate.Web.Features.Dashboard.Components

<PageTitle>Dashboard</PageTitle>

<WelcomeSection />

<MudGrid>
    @foreach (var metric in _metrics)
    {
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MetricCard Metric="@metric" />
        </MudItem>
    }
</MudGrid>

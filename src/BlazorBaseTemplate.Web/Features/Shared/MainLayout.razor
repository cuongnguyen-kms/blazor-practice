@namespace BlazorBaseTemplate.Web.Features.Shared
@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="BlazorBaseTemplate.Web.Themes.CustomTheme.AppTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">BlazorBaseTemplate</MudText>
        <MudSpacer />
        <ThemeToggle @bind-IsDarkMode="_isDarkMode" @bind-IsDarkMode:after="PersistDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Class="glassmorphism-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-6 page-enter">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

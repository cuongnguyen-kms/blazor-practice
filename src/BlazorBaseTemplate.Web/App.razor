<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(App).Assembly"
        AdditionalAssemblies="new[] { typeof(App).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(BlazorBaseTemplate.Web.Features.Shared.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(BlazorBaseTemplate.Web.Features.Shared.MainLayout)">
            <MudText Typo="Typo.h6" Color="MudBlazor.Color.Error">Sorry, there's nothing at this address.</MudText>
        </LayoutView>
    </NotFound>
</Router>
